    # Teardown
    teardown_parser = subparsers.add_parser("teardown", help="Destroy the stack")
    teardown_parser.add_argument(
        "--clean", action="store_true", help="Delete generated config files"
    )

    # Status (NEW)
    subparsers.add_parser("status", help="Live observability dashboard")

    # Audit (NEW)
    subparsers.add_parser("audit", help="Generate Markdown audit report")

    args = parser.parse_args()

    if args.command == "init":
        init(args)
    elif args.command == "validate":
