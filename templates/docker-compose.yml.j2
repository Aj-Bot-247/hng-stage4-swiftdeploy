version: "3.8"

services:
  api:
    image: {{ manifest.services.image }}
    user: "appuser"
    cap_drop:
      - ALL
    environment:
      - MODE={{ mode }}
      - APP_VERSION=1.0.0
      - APP_PORT={{ manifest.services.port }}
    networks:
      - {{ manifest.network.name }}
    restart: always
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://127.0.0.1:{{ manifest.services.port }}/healthz"]
      interval: 10s
      timeout: 5s
      retries: 3
      start_period: 5s

  nginx:
    image: {{ manifest.nginx.image }}
    ports:
      - "{{ manifest.nginx.port }}:{{ manifest.nginx.port }}"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - swiftdeploy_logs:/var/log/nginx
    networks:
      - {{ manifest.network.name }}
    depends_on:
      api:
        condition: service_healthy
    restart: always

networks:
  {{ manifest.network.name }}:
    driver: {{ manifest.network.driver_type }}

volumes:
  swiftdeploy_logs: